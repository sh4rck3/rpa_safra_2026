# Browser settings (optional)
HEADLESS=False
BROWSER_TIMEOUT=30

# API Settings (para modo servidor distribuído)
API_HOST=0.0.0.0
API_PORT=8000
MACHINE_ID=MAQUINA_01
TIMEOUT_INATIVIDADE=600
