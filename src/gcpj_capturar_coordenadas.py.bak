    # Perguntar se quer fechar o Chrome
    print("="*70)
    fechar = input("\n❓ Deseja fechar o Chrome agora? (s/n): ").strip().lower()
    
    if fechar == 's':
        print("🔴 Fechando Chrome...")
        if driver:
            driver.quit()
        print("✅ Chrome fechado!")
    else:
        print("💡 Chrome permanecerá aberto. Feche manualmente quando quiser.")

if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\n\n⚠️  Captura cancelada pelo usuário!")
        if driver:
            print("🔴 Fechando Chrome...")
            driver.quit()
    except Exception as e:
        print(f"\n\n❌ ERRO: {e}")
        print(f"   Tipo: {type(e).__name__}")
        import traceback
        traceback.print_exc()
        if driver:
            print("🔴 Fechando Chrome...")
            driver.quit()
