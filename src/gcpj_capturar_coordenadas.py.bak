            "   (que apareceu após selecionar GCPJ)"
        )
        salvar_coordenadas(coordenadas)
    else:
        print(f"\n✓ botao_acessar já existe, pulando..."pyautogui.click(coordenadas["item_gcpj_menu"]["x"], 
